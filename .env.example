# Database (MySQL)
DATABASE_URL="mysql://root:password@localhost:3306/trs_web"

# Public site URL (optional — used for JSON-LD and canonical URLs)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# Support agent PWA (/chat-app or https://chats.yourdomain.com)
# Dedicated secret recommended in production (defaults to NEXTAUTH_SECRET if unset):
# CHAT_SUPPORT_JWT_SECRET="long-random-string"
# Main site URL (canonical, JSON-LD) — use https on VPS:
# NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# Web Push (support PWA — new visitor messages). Generate: npx web-push generate-vapid-keys
# Site must be served over HTTPS in production for push + install.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY="..."
# VAPID_PRIVATE_KEY="..."
# VAPID_SUBJECT="mailto:support@yourdomain.com"

# Optional: persistent upload directory for PM2 standalone (avoids losing files when copying public/ after build).
# UPLOAD_DIR="/var/lib/trs-web/uploads"

# Admin seed credentials
ADMIN_EMAIL="admin@trs.com"
ADMIN_PASSWORD="admin123"
