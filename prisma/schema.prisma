generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("admin") @db.VarChar(50)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  @db.VarChar(50)
  provider          String  @db.VarChar(50)
  providerAccountId String  @db.VarChar(100)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(50)
  scope             String? @db.Text
  id_token          String? @db.Text
  session_state     String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @db.VarChar(255)
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String   @db.VarChar(255)
  token      String   @unique @db.VarChar(255)
  expires    DateTime

  @@unique([identifier, token])
}

model Page {
  id              String   @id @default(cuid())
  slug            String   @unique @db.VarChar(255)
  title           String   @db.VarChar(255)
  content         Json?
  heroTitle       String?  @db.VarChar(255)
  heroSubtitle    String?  @db.VarChar(255)
  heroImage       String?  @db.VarChar(500)
  metaDescription String?  @db.Text
  published       Boolean  @default(false)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Service {
  id            String   @id @default(cuid())
  title         String   @db.VarChar(255)
  slug          String   @unique @db.VarChar(255)
  description   String   @db.Text
  coverImage    String?  @db.VarChar(500)
  detailContent String?  @db.LongText
  icon          String?  @db.VarChar(100)
  features      Json?
  order         Int      @default(0)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PortfolioItem {
  id           String    @id @default(cuid())
  title        String    @db.VarChar(255)
  slug         String    @unique @db.VarChar(255)
  description  String    @db.Text
  content      String?   @db.LongText
  client       String?   @db.VarChar(255)
  category     String?   @db.VarChar(100)
  technologies Json?
  imageUrl     String?   @db.VarChar(500)
  gallery      Json?
  featured     Boolean   @default(false)
  completedAt  DateTime?
  published    Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(255)
  role      String   @db.VarChar(255)
  bio       String?  @db.Text
  imageUrl  String?  @db.VarChar(500)
  email     String?  @db.VarChar(255)
  linkedin  String?  @db.VarChar(500)
  twitter   String?  @db.VarChar(500)
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(255)
  role      String?  @db.VarChar(255)
  company   String?  @db.VarChar(255)
  content   String   @db.Text
  imageUrl  String?  @db.VarChar(500)
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  excerpt     String?   @db.Text
  content     String    @db.LongText
  coverImage  String?   @db.VarChar(500)
  category    String?   @db.VarChar(100)
  tags        Json?
  authorId    String?   @db.VarChar(100)
  authorName  String?   @db.VarChar(255)
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  company   String?  @db.VarChar(255)
  subject   String?  @db.VarChar(255)
  message   String   @db.Text
  status    String   @default("new") @db.VarChar(50)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique @db.VarChar(100)
  value String @db.Text
}
